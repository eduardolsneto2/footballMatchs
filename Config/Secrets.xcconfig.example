// Copy this file to Secrets.xcconfig if you want to override local backend settings.
// For a real iPhone device, replace 127.0.0.1 with your Mac's local network IP.
//
// Must be a full URL with host and port (NOT http://api — that produces broken requests like http://api/v1/...).
BACKEND_BASE_URL = http://127.0.0.1:8000
